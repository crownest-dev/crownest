{
  "name": "crownest",
  "version": "0.1.0",
  "private": true,
  "type": "module",
  "packageManager": "pnpm@10.23.0",
  "scripts": {
    "build": "turbo build",
    "format": "prettier . --write",
    "format:check": "prettier . --check",
    "lint": "eslint --max-warnings=0 .",
    "test": "turbo test",
    "test:python-sdk": "uv run --project packages/python-sdk pytest packages/python-sdk/tests",
    "typecheck": "turbo typecheck",
    "verify": "pnpm build && pnpm lint && pnpm typecheck && pnpm test && pnpm test:python-sdk && pnpm format:check"
  },
  "devDependencies": {
    "@eslint/js": "^9.39.1",
    "@types/node": "^24.10.1",
    "eslint": "^9.39.1",
    "eslint-config-prettier": "^10.1.8",
    "eslint-plugin-eslint-comments": "^3.2.0",
    "eslint-plugin-simple-import-sort": "^12.1.1",
    "eslint-plugin-unused-imports": "^4.3.0",
    "globals": "^16.5.0",
    "prettier": "^3.6.2",
    "turbo": "^2.8.17",
    "typescript": "^5.9.3",
    "typescript-eslint": "^8.48.0",
    "vitest": "^4.1.6"
  }
}
