{
  "name": "@crownest/ai-sdk",
  "version": "0.1.1",
  "description": "Vercel AI SDK tools for CrowNest cloud sandboxes.",
  "license": "Apache-2.0",
  "type": "module",
  "homepage": "https://crownest.dev/docs",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/crownest-dev/crownest.git",
    "directory": "packages/ai-sdk"
  },
  "bugs": {
    "url": "https://github.com/crownest-dev/crownest/issues"
  },
  "keywords": [
    "sandbox",
    "ai-agents",
    "code-interpreter",
    "code-execution",
    "ai-sdk"
  ],
  "engines": {
    "node": ">=18"
  },
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./src/index.ts",
      "import": "./src/index.ts"
    }
  },
  "files": [
    "dist/index.js",
    "dist/index.d.ts",
    "dist/session.d.ts",
    "dist/tools.d.ts",
    "README.md",
    "LICENSE"
  ],
  "publishConfig": {
    "access": "public",
    "exports": {
      ".": {
        "types": "./dist/index.d.ts",
        "import": "./dist/index.js"
      }
    }
  },
  "scripts": {
    "build": "tsc -p tsconfig.build.json && node ../../scripts/rewrite-dts-extensions.mjs dist && esbuild src/index.ts --bundle --platform=neutral --format=esm --target=es2022 --external:@crownest/sdk --external:ai --external:zod --external:zod/* --outfile=dist/index.js",
    "test": "vitest run",
    "typecheck": "tsc --noEmit"
  },
  "dependencies": {
    "@crownest/sdk": "workspace:*",
    "zod": "^4.4.3"
  },
  "peerDependencies": {
    "ai": "^6.0.0"
  },
  "devDependencies": {
    "ai": "^6.0.0",
    "esbuild": "^0.28.0",
    "vitest": "^4.1.6"
  }
}
