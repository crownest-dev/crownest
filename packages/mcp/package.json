{
  "name": "@crownest/mcp",
  "version": "0.1.1",
  "description": "MCP stdio server for CrowNest cloud sandboxes.",
  "license": "Apache-2.0",
  "type": "module",
  "homepage": "https://crownest.dev/docs",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/crownest-dev/crownest.git",
    "directory": "packages/mcp"
  },
  "bugs": {
    "url": "https://github.com/crownest-dev/crownest/issues"
  },
  "keywords": [
    "sandbox",
    "ai-agents",
    "code-interpreter",
    "code-execution",
    "mcp"
  ],
  "engines": {
    "node": ">=18"
  },
  "bin": {
    "crownest-mcp": "./dist/index.js"
  },
  "exports": {
    ".": {
      "import": "./dist/index.js"
    }
  },
  "files": [
    "dist",
    "README.md",
    "LICENSE"
  ],
  "publishConfig": {
    "access": "public"
  },
  "scripts": {
    "build": "esbuild src/index.ts --bundle --platform=node --format=esm --target=node18 --outfile=dist/index.js",
    "test": "vitest run",
    "typecheck": "tsc --noEmit"
  },
  "dependencies": {
    "@modelcontextprotocol/sdk": "^1.29.0",
    "zod": "^4.4.3"
  },
  "devDependencies": {
    "@crownest/sdk": "workspace:*",
    "esbuild": "^0.28.0",
    "tsx": "^4.21.0"
  }
}
